# ==============================================================================
# ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to `.env` or `.env.local` and fill in the values.
# Example:
#   cp .env.example .env.local

# ── CROO SDK KEY ────────────────────────────────────────────────────
# Your CROO Agent SDK key (croo_sk_...) from the CROO Dashboard.
# Required in LIVE mode. Omit only when running with CROO_MOCK=true.
CROO_SDK_KEY=

# ── GAUNTLET SERVICE ID ─────────────────────────────────────────────
# The registered service ID for this certification agent. Register the
# service in the CROO Dashboard, then paste its ID here.
GAUNTLET_SERVICE_ID=

# ── HEALTH / BADGE SERVER PORT (optional) ───────────────────────────
# Port for the health check and dynamic certification badge endpoint.
# Defaults to 8080.
# PORT=8080

# ── MOCK MODE (optional) ────────────────────────────────────────────
# Set to true for offline development — no USDC spent, no WebSocket opened.
# CROO_MOCK=true
