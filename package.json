{
  "name": "dorahacks-croo-gauntlet",
  "version": "0.1.0",
  "description": "Paid certification agent — hires your agent with 7 adversarial probes and delivers a scorecard",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --silent --coverage",
    "certify": "tsx scripts/certify-all.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=high || true",
    "ci": "npm run audit && npm run lint && npm run typecheck && npm run test:coverage"
  },
  "keywords": [
    "croo",
    "agent",
    "a2a",
    "certification",
    "testing"
  ],
  "license": "MIT",
  "dependencies": {
    "@croo-network/sdk": "^0.2.1",
    "@edycutjong/croo-core": "^0.3.0",
    "pdfkit": "^0.19.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/pdfkit": "^0.17.6",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.0.0",
    "license-checker": "^25.0.1",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.8"
  }
}
